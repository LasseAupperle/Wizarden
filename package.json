{
  "name": "wizarden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm --filter @wizarden/shared run build && pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @wizarden/server run dev",
    "dev:client": "pnpm --filter @wizarden/client run dev",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.2"
  },
  "packageManager": "pnpm@11.8.0"
}
