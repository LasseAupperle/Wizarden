# Server runtime env. Copy to .env for local dev (server reads process.env).
# PORT is provided by Render in production; locally defaults to 3001.
PORT=3001
# The client origin allowed for CORS + Socket.IO. In prod = the Netlify origin.
CLIENT_ORIGIN=http://localhost:5173
# "true" enables debug-only server actions (bots, 2-seat start). Keep "false" in prod.
ENABLE_DEBUG=true
# Optional: Upstash Redis URL for a persistent leaderboard. Leave unset = in-memory.
# Use the rediss:// (TLS) form, e.g. rediss://default:<password>@<host>.upstash.io:6379
# REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
